# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
Thumbs.db
Desktop.ini

# debug & crash logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
hs_err_pid*
replay_pid*

# env files (never commit secrets)
.env*
!.env.example
.env.local

docs/*
docs/superpowers/*
# local database
/data/

# source PDF (~44MB) — use Vercel Blob in production
*.pdf
!/docs/**/*.pdf

# Source image masters (Canva, backups, etc.)
/source/**/*.png
/source/**/*.jpg
/source/**/*.jpeg
/source/**/*.webp
/source/**/*.pdf
/source/backup/

# Legacy magazine export (superseded by page-*.png + pages.json)
/public/magazine/sheet-*
/public/magazine/sheets.json

# vercel
.vercel

# typescript
*.tsbuildinfo

# python (export script)
__pycache__/
*.py[cod]
.venv/
venv/

# IDE / editor
.idea/
.vscode/
*.swp
.cursor/

# NOTE: Commit public/magazine/page-*.png and pages.json after `npm run export:magazine`
# (~200MB). Required for Vercel unless you add Canva/PDF to the build environment.
