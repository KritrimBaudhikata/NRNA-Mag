SITE_URL=https://everestday.nrnahk.org
TOKEN_SECRET=generate-a-long-random-string
# Local: file:./data/verifications.db
# Turso: libsql://your-db-name-org.turso.io (requires token below)
DATABASE_URL=file:./data/verifications.db
DATABASE_AUTH_TOKEN=
# alias for Turso docs:
# TURSO_AUTH_TOKEN=

# Resend: use a Full access API key (not send-only) to add contacts to segments
RESEND_API_KEY=
# Segment ID from Resend → Segments (or legacy Audience ID)
RESEND_SEGMENT_ID=
RESEND_AUDIENCE_ID=
RESEND_FROM_EMAIL=magazine@nrnahk.org

# Production: upload PDF to Vercel Blob
BLOB_READ_WRITE_TOKEN=
PDF_BLOB_PATH=everest-day-2026.pdf

# Local dev: path to source PDF (defaults also try "NRNA HK Everest Day_2.pdf" in project root)
PDF_LOCAL_PATH=./NRNA HK Everest Day_2.pdf
